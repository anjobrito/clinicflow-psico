generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AjbAdminUser {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String   @default("AJB_ADMIN")
  active    Boolean  @default(true)
  blocked   Boolean  @default(false)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  actions AjbAuditLog[]
}

model AjbAuditLog {
  id          String   @id @default(cuid())
  adminUserId String?
  action      String
  targetType  String
  targetId    String?
  description String?
  createdAt   DateTime @default(now())

  adminUser AjbAdminUser? @relation(fields: [adminUserId], references: [id])

  @@index([targetType, targetId])
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  document  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinics  Clinic[]
  licenses License[]
}

model License {
  id        String   @id @default(cuid())
  tenantId  String
  plan      String   @default("STARTER")
  status    String   @default("TRIAL")
  seats     Int      @default(1)
  startsAt  DateTime @default(now())
  expiresAt DateTime?
  blockedAt DateTime?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
}

model Clinic {
  id        String   @id @default(cuid())
  tenantId  String?
  name      String
  document  String?
  phone     String?
  email     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant? @relation(fields: [tenantId], references: [id])
  users        User[]
  patients     Patient[]
  appointments Appointment[]
  payments     Payment[]

  @@index([tenantId])
}

model User {
  id        String   @id @default(cuid())
  clinicId  String
  name      String
  email     String
  role      String   @default("PSYCHOLOGIST")
  active    Boolean  @default(true)
  blocked   Boolean  @default(false)
  blockedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id])

  @@unique([clinicId, email])
  @@index([clinicId, role])
  @@index([clinicId, active])
}

model Patient {
  id        String   @id @default(cuid())
  clinicId  String
  name      String
  document  String?
  birthDate DateTime?
  phone     String?
  email     String?
  insurance String   @default("Particular")
  status    String   @default("ACTIVE")
  valueCents Int     @default(0)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic       Clinic        @relation(fields: [clinicId], references: [id])
  appointments Appointment[]
  payments     Payment[]
  documents    PsychologicalDocument[]

  @@index([clinicId])
}

model Appointment {
  id        String   @id @default(cuid())
  clinicId  String
  patientId String
  date      DateTime
  time      String
  duration  Int      @default(50)
  room      String?
  mode      String   @default("IN_PERSON")
  status    String   @default("SCHEDULED")
  valueCents Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic    Clinic @relation(fields: [clinicId], references: [id])
  patient   Patient @relation(fields: [patientId], references: [id])
  evolution EvolutionNote?
  payment   Payment?

  @@index([clinicId, date])
  @@index([patientId])
}

model EvolutionNote {
  id            String   @id @default(cuid())
  appointmentId String  @unique
  patientId     String
  content       String
  status        String  @default("DRAFT")
  finalizedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id])
}

model Payment {
  id            String   @id @default(cuid())
  clinicId      String
  appointmentId String   @unique
  patientId     String
  amountCents   Int
  status        String   @default("PENDING")
  method        String   @default("PIX")
  dueDate       DateTime?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  clinic      Clinic      @relation(fields: [clinicId], references: [id])
  appointment Appointment @relation(fields: [appointmentId], references: [id])
  patient     Patient     @relation(fields: [patientId], references: [id])

  @@index([clinicId, status])
}

model PsychologicalDocument {
  id        String   @id @default(cuid())
  clinicId  String
  patientId String
  type      String
  title     String
  content   String
  status    String   @default("DRAFT")
  issuedAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([clinicId, type])
  @@index([patientId])
}
